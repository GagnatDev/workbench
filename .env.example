# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8080

# Postgres (matches docker-compose). Primary var is DATABASE_URL.
DATABASE_URL=postgresql://workbench:workbench@localhost:5432/workbench

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# AUTH_MODE / VITE_DISABLE_AUTH are NOT set here — they are owned by the per-mode
# overlay files at the repo root and selected by the pnpm scripts:
#   pnpm dev          -> .env.development  (AUTH_MODE=dev, offline fixed dev user)
#   pnpm dev:homectl  -> .env.homectl      (AUTH_MODE=homectl, real OAuth2)
# This base .env only holds the shared/secret/host-specific config below. The
# homectl bits (AUTH_SERVICE_URL, VITE_AUTH_SERVICE_URL, WORKBENCH_CLIENT_SECRET)
# must be filled in here so `pnpm dev:homectl` works with no further edits.

# Public base URL of this app (used for the OAuth redirect_uri).
APP_BASE_URL=http://localhost:3000
# homectl-auth service base URL (public — JWT issuer, browser redirects,
# invite redemption links).
AUTH_SERVICE_URL=https://auth.homectl.no
# In-cluster address for server-to-server auth calls (token exchange, JWKS,
# invite forwarding). Set in k8s to use service discovery and keep backend
# traffic off the public auth ingress; leave unset locally to fall back to
# AUTH_SERVICE_URL.
# AUTH_INTERNAL_URL=http://homectl-auth.homectl.svc.cluster.local
# OAuth client id (must match the app id registered in homectl-auth apps.json).
AUTH_CLIENT_ID=workbench
# Plaintext client secret the app presents at /token (bcrypt-hashed on the auth side).
# WORKBENCH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Object storage (Phase 3+; Scaleway S3-compatible / MinIO locally)
# ---------------------------------------------------------------------------
# Uncomment to enable photo attachments locally (matches docker-compose MinIO).
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=fr-par
# S3_BUCKET=homectl-workbench
# S3_ACCESS_KEY_ID=workbench
# S3_SECRET_ACCESS_KEY=workbench-dev-secret
# S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
# VITE_DISABLE_AUTH is set by the overlay files (see the Auth section above).
# VITE_AUTH_SERVICE_URL must match AUTH_SERVICE_URL for `pnpm dev:homectl`.
# VITE_AUTH_SERVICE_URL=https://auth.homectl.no
# VITE_API_URL=
