# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8080

# Postgres (matches docker-compose). Primary var is DATABASE_URL.
DATABASE_URL=postgresql://workbench:workbench@localhost:5432/workbench

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Auth is handled by the homectl-auth-proxy sidecar in production: it runs the
# OAuth flow and injects X-Homectl-* identity headers the backend reads. The app
# itself holds no token and does no auth work.
#
# AUTH_MODE is owned by the per-mode overlay at the repo root, selected by the
# pnpm script:
#   pnpm dev  -> .env.development  (AUTH_MODE=dev, offline fixed dev user)
# In `dev` mode there's no sidecar in front, so the backend synthesizes a local
# identity. To exercise the real sidecar locally, run the homectl-auth-proxy
# container with DEV_FAKE_IDENTITY (see the sidecar integration guide §7).
#
# The vars below are only used by the invite forwarder (POST /api/invites); they
# are not needed for normal auth. Fill them in only if testing invites locally.

# homectl-auth service base URL (public — used to build the invite redemption
# link a human clicks).
AUTH_SERVICE_URL=https://auth.homectl.no
# In-cluster address for server-to-server auth calls (invite forwarding). Set in
# k8s to use service discovery and keep backend traffic off the public auth
# ingress; leave unset locally to fall back to AUTH_SERVICE_URL.
# AUTH_INTERNAL_URL=http://homectl-auth.homectl.svc.cluster.local
# App id registered in homectl-auth apps.json; sent as the invite appId.
AUTH_CLIENT_ID=workbench

# ---------------------------------------------------------------------------
# Object storage (Phase 3+; Scaleway S3-compatible / MinIO locally)
# ---------------------------------------------------------------------------
# Uncomment to enable photo attachments locally (matches docker-compose MinIO).
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=fr-par
# S3_BUCKET=homectl-workbench
# S3_ACCESS_KEY_ID=workbench
# S3_SECRET_ACCESS_KEY=workbench-dev-secret
# S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
# The SPA is auth-agnostic (no token, no knowledge of the auth service) — it just
# makes same-origin calls. Only the API base URL is configurable; leave it empty
# for same-origin (the backend serves the SPA in the single-container image).
# VITE_API_URL=
