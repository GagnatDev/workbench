{
  "name": "@workbench/backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "workbench-backend": "dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../.env --env-file-if-exists=../.env.development src/server.ts",
    "dev:homectl": "tsx watch --env-file-if-exists=../.env --env-file-if-exists=../.env.homectl src/server.ts",
    "build": "tsc --noEmit && tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@gagnatdev/homectl-auth-client": "0.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "kysely": "^0.27.4",
    "node-pg-migrate": "^7.9.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vitest": "^3.2.4"
  }
}
