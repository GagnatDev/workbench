{
  "name": "workbench",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "dev:frontend": "pnpm --filter @workbench/frontend run dev",
    "dev:backend": "pnpm --filter @workbench/backend run dev",
    "test:e2e": "pnpm --filter @workbench/e2e run test:e2e"
  }
}
