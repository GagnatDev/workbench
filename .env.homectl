# homectl auth overlay — loaded by `pnpm dev:homectl` (Vite --mode homectl;
# backend via --env-file-if-exists). Runs the real OAuth2 flow against
# homectl-auth.
#
# Host-specific / secret bits (AUTH_SERVICE_URL, VITE_AUTH_SERVICE_URL,
# WORKBENCH_CLIENT_SECRET) stay in the gitignored root .env, so switching modes
# never needs a manual edit. Committed on purpose — no secrets live here.
AUTH_MODE=homectl
VITE_DISABLE_AUTH=false
