# Dev auth overlay — loaded automatically by `pnpm dev` (backend via
# --env-file-if-exists). Offline: with no auth-proxy sidecar in front, the
# backend synthesizes a fixed dev user for every request, so the whole pipeline
# runs with no auth service. This is the common local default.
#
# Layered on top of the gitignored root .env (shared/secret config). Committed on
# purpose — it contains no secrets, so the whole team gets dev auth for free.
AUTH_MODE=dev
