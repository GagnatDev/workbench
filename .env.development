# Dev auth overlay — loaded automatically by `pnpm dev` (Vite mode=development;
# backend via --env-file-if-exists). Offline: every request resolves to a fixed
# dev user, no auth service needed. This is the common local default.
#
# Layered on top of the gitignored root .env (shared/secret config). Committed on
# purpose — it contains no secrets, so the whole team gets dev auth for free.
AUTH_MODE=dev
VITE_DISABLE_AUTH=true
