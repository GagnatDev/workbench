# Build output
build/
**/build/
out/
dist/
web/

# npm / Node
node_modules/
npm-debug.log*
.pnpm-debug.log*
.npm
# .npmrc holds the GitHub Packages token for @gagnatdev/* — never commit it.
.npmrc

# Frontend build / tooling
.vite/
*.tsbuildinfo
*.local
# Compiled output of vite.config.ts — Vite resolves .js before .ts, so a stray
# vite.config.js silently shadows the real config. Never commit it.
frontend/vite.config.js
frontend/vite.config.d.ts
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.iml
.project
.settings/

# OS
.DS_Store
Thumbs.db

# Editor / merge backups
*.orig
*~
*.bak
*.swp
*.swo

# Logs and temp
*.log
*.tmp
*.temp
.cache/
.issues/

# Test / coverage
coverage/
.nyc_output/
*.lcov
frontend/test-results/
frontend/playwright-report/

# E2E (Playwright) artifacts
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/.cache/
